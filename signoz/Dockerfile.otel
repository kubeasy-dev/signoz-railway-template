FROM signoz/signoz-otel-collector:v0.144.2

COPY ./otel-collector-config.yaml /etc/otel-collector-config.yaml
# Override OpAMP endpoint to unreachable address so SigNoz never pushes
# its config (which lacks the logs pipeline) over the static config.
RUN printf 'server_endpoint: ws://127.0.0.1:1/v1/opamp\n' > /etc/manager-config.yaml

CMD ["--config=/etc/otel-collector-config.yaml", "--copy-path=/tmp/collector-opamp-override.yaml"]
